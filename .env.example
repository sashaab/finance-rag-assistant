# ── LLM (generative model) ────────────────────────────────────────────────────
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=mistralai/mistral-small-3.2-24b-instruct

# ── Embedder / Reranker ────────────────────────────────────────────────────────
EMBEDDER_API_KEY=your_embedder_api_key_here
EMBEDDER_MODEL=intfloat/multilingual-e5-base
RERANKER_URL=https://api.openai.com/v1/rerank
RERANKER_MODEL=Qwen/Qwen3-Reranker-4B

# ── Data paths ─────────────────────────────────────────────────────────────────
TRAIN_DATA_PATH=train_data.csv
QUESTIONS_PATH=questions.csv
EMBEDDINGS_CACHE=embeddings.pkl
OUTPUT_PATH=submission.csv

# ── Pipeline tuning ────────────────────────────────────────────────────────────
CHUNK_MAX_LEN=400
CHUNK_MIN_LEN=50
RETRIEVAL_TOP_K=100
RERANK_TOP_K=5
CONTEXT_MIN_LEN=150
GENERATION_TEMPERATURE=0.4
